{
  "$schema": "https://raw.githubusercontent.com/nicxlasj/tauri-settings-schema/refs/heads/main/schema.json",
  "productName": "mdd-ui",
  "version": "0.1.0",
  "identifier": "io.github.eclipse-opensovd.mdd-ui",
  "build": {
    "frontendDist": "frontend/dist",
    "devUrl": "http://localhost:5173",
    "beforeDevCommand": "bun install && bun run dev",
    "beforeBuildCommand": "bun install && bun run build"
  },
  "app": {
    "windows": [
      {
        "title": "",
        "width": 1280,
        "height": 800,
        "minWidth": 800,
        "minHeight": 600,
        "resizable": true,
        "theme": "Dark",
        "titleBarStyle": "Overlay"
      }
    ],
    "security": {
      "csp": null
    }
  },
  "bundle": {
    "active": true,
    "targets": "all",
    "createUpdaterArtifacts": true,
    "windows": {
      "nsis": {
        "installMode": "both"
      }
    },
    "icon": [
      "icons/32x32.png",
      "icons/128x128.png",
      "icons/128x128@2x.png",
      "icons/icon.icns",
      "icons/icon.ico",
      "icons/icon.png"
    ],
    "fileAssociations": [
      {
        "ext": ["mdd"],
        "name": "MDD Database",
        "description": "Diagnostic database file",
        "mimeType": "application/x-mdd",
        "role": "Viewer"
      }
    ]
  },
  "plugins": {
    "updater": {
      "pubkey": "dW50cnVzdGVkIGNvbW1lbnQ6IG1pbmlzaWduIHB1YmxpYyBrZXk6IENERTVGRjAyOTAzMTM4OUEKUldTYU9ER1FBdi9semR0SDlJSjl1aWYyaTdQaHEvbW9mVWxMa1ZLNXE2VWV6UWV1OVM2Vnk2NmIK",
      "endpoints": [
        "https://github.com/eclipse-opensovd/mdd-ui/releases/latest/download/latest.json"
      ],
      "windows": {
        "installMode": "passive"
      }
    }
  }
}
